# Copy this file to .env.docker for local infrastructure secrets.
#
# Run with:
#   docker compose --env-file .env.docker up -d

POSTGRES_DB=bess_invoice
POSTGRES_USER=bess_app
POSTGRES_PASSWORD=bluedesk
POSTGRES_PORT=5433

MINIO_ROOT_USER=bess_minio
MINIO_ROOT_PASSWORD=change-me-minimum-8-characters
MINIO_BUCKET=bess-files
MINIO_API_PORT=9001
MINIO_CONSOLE_PORT=9002

# Streamlit app configuration.
DATABASE_URL=postgresql://bess_app:bluedesk@localhost:5433/bess_invoice

# Optional user-attribution placeholder.
AUTH_EMAIL_FROM=no-reply@example.com
