# Copy this file to .env.docker for local infrastructure secrets.
#
# Run with:
#   docker compose --env-file .env.docker up -d

POSTGRES_DB=bess_invoice
POSTGRES_USER=bess_app
POSTGRES_PASSWORD=bluedesk
POSTGRES_PORT=5433

MINIO_ROOT_USER=bess_minio
MINIO_ROOT_PASSWORD=change-me-minimum-8-characters
MINIO_BUCKET=bess-files
MINIO_API_PORT=9001
MINIO_CONSOLE_PORT=9002

# Streamlit app configuration for future database/object-store integration.
DATABASE_URL=postgresql://bess_app:bluedesk@localhost:5433/bess_invoice
S3_ENDPOINT_URL=http://localhost:9001
S3_ACCESS_KEY_ID=bess_minio
S3_SECRET_ACCESS_KEY=change-me-minimum-8-characters
S3_BUCKET=bess-files
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# Streamlit email authentication placeholders.
# Use your provider values in deployed environments.
AUTH_EMAIL_FROM=no-reply@example.com
AUTH_ALLOWED_USERS=
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_USE_TLS=true
